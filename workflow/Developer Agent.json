    {
      "parameters": {
        "jsCode": "const rawText = $input.item.json.text || $input.item.json.response || $input.item.json.output || $input.item.json.content || \"\";\n\nconst files = [];\nconst parts = rawText.split(/===FILE:\\s*([^\\s]+)===\\s*/g);\n\nfor (let i = 1; i < parts.length; i += 2) {\n  const path = parts[i].trim();\n  const content = parts[i + 1] ? parts[i + 1].trim() : \"\";\n  \n  if (path && content) {\n    files.push({\n      path: path,\n      content: content\n    });\n  }\n}\n\nif (files.length === 0) {\n  throw new Error(\"No files could be parsed. Check the LLM output format.\");\n}\n\n// FORCE N8N TO LOOK BACK AT THE WORKFLOW ENTRY DOOR FOR METADATA\nlet projectId = \"\";\nlet category = \"code snippets\";\n\ntry {\n  // Directly targeting the execution root block of Workflow 10\n  const rootTrigger = $('When Executed by Another Workflow').first().json;\n  projectId = rootTrigger.projectId || \"\";\n  category = rootTrigger.category || \"code snippets\";\n} catch (e) {\n  // Fallback if the node name is slightly different\n  projectId = $json.projectId || \"\";\n}\n\n// Return the files properly formatted with data inside the json object\nreturn files.map(file => {\n  return {\n    json: {\n      path: file.path,\n      content: file.content,\n      projectId: projectId,\n      category: category,\n      text: rawText\n    }\n  };\n});"
      },
