    {
      "parameters": {
        "jsCode": "// Import the native Node.js File System module built right into your server\nconst fs = require('fs');\nconst path = require('path');\n\n// 1. Fetch ALL 7 file items coming into this node from the Merge node\nconst items = $input.all();\n\n// 2. Reach directly back to your original \"Code\" node to grab your parent metadata\nconst originalJson = $node[\"Code\"].json;\n\n// Target workspace directory\nconst baseDir = 'E:/jwt-auth-server';\n\n// 3. Loop through every single file item in the array to write them all\nfor (const item of items) {\n  const fileRelativePath = item.json.path;\n  const fileContent = item.json.content;\n  \n  if (!fileRelativePath || !fileContent) continue;\n\n  const fullPath = path.join(baseDir, fileRelativePath);\n\n  try {\n    const dirName = path.dirname(fullPath);\n    if (!fs.existsSync(dirName)) {\n      fs.mkdirSync(dirName, { recursive: true });\n    }\n    fs.writeFileSync(fullPath, fileContent, 'utf8');\n  } catch (error) {\n    throw new Error(`Failed to write file to disk via Node.js: ${error.message}`);\n  }\n}\n\n// 4. FORCE the node to return your clean text fields back to the main workflow loop\nreturn [{\n  json: {\n    projectId: originalJson.projectId || \"34d5571b-3d69-4cfa-99a9-60ca5d4b7b6a\",\n    category: originalJson.category || \"code snippets\",\n    text: originalJson.text || \"Code generated successfully.\",\n    source: \"developer\"\n  }\n}];"
      },
