    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Please classify this text snippet:\n{{ $json.text }}\n\nRespond with ONLY a valid, minified JSON object containing these two exact keys:\n{\n  \"category\": \"Requirements\",\n  \"summary\": \"Short description\"\n}",
        "messages": {
          "messageValues": [
            {
              "message": "=Analyze the following raw snippet from a development session. Classify it into exactly ONE of these categories: \"Requirements\", \"Decisions\", \"Research\", \"Tasks\", \"Bugs\", or \"Architecture Notes\".\n\nContent: \"{{ $json.text }}\"\n\nReturn a clean JSON object with two fields:\n\"category\": The classified category string.\n\"summary\": A brief, one-sentence summary of the core insight."
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -144,
        -16
      ],
      "id": "d0e9c0e9-9441-4bc3-809c-d45ff330b29d",
      "name": "Basic LLM Chain"
    },
    {
      "parameters": {
        "jsCode": "// Grab the raw text coming directly from Gemini\nlet geminiResponse = $input.item.json.text;\n\n// Strip out any markdown wraps (```json or ```) that Gemini adds\ngeminiResponse = geminiResponse.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\ntry {\n  // Parse the clean string into real data properties\n  const parsedData = JSON.parse(geminiResponse);\n  \n  return [{\n    json: {\n      category: parsedData.category || \"Architecture Notes\",\n      summary: parsedData.summary || \"Development insight recorded.\"\n    }\n  }];\n} catch (error) {\n  // Safe fallback object so the workflow never crashes if text formatting is weird\n  return [{\n    json: {\n      category: \"Architecture Notes\",\n      summary: \"Raw dev session entry recorded.\"\n    }\n  }];\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        128,
        -16
      ],
      "id": "ef7d5094-0c8e-460a-98fc-e595d67fa97c",
      "name": "Code in JavaScript"
    },
    {
