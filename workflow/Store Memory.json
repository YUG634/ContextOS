        "tableId": "project_memories",
        "fieldsUi": {
          "fieldValues": [
            {
              "fieldId": "project_id",
              "fieldValue": "={{ $json.projectId }}"
            },
            {
              "fieldId": "category",
              "fieldValue": "={{ $json.category }}"
            },
            {
              "fieldId": "content",
              "fieldValue": "={{ JSON.parse($json.rawContent).summary }}"
            },
            {
              "fieldId": "source",
              "fieldValue": "={{ $json.source || \"developer\" }}"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.supabase",
